{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "outDir": "./dist-server",
        "rootDir": ".",
        "skipLibCheck": true,
        "esModuleInterop": true,
        "strict": false,
        "noEmit": false,
        "resolveJsonModule": true,
        "allowJs": true,
        "jsx": "react-jsx",
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "./src/*"
            ]
        }
    },
    "include": [
        "server/index.ts"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "dist-server",
        "src"
    ]
}